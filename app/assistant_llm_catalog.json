{
  "default_provider": "ollama",
  "providers": [
    {
      "id": "ollama",
      "label": "Ollama",
      "default_base_url": "http://127.0.0.1:11434",
      "supports_custom_base_url": true,
      "supports_custom_model": true,
      "model_placeholder": "llama3.2",
      "api_key_mode": "optional",
      "api_key_label": "API key (opt.)",
      "api_key_placeholder": "empty = local",
      "transport": {
        "type": "http-json",
        "method": "POST",
        "path": "/api/chat",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "model": "${model}",
          "stream": false,
          "messages": [
            { "role": "system", "content": "${system_prompt}" },
            { "role": "user", "content": "${user_prompt}" }
          ],
          "options": {
            "temperature": "${temperature}"
          }
        },
        "response_text_paths": ["message.content"]
      },
      "models": [
        { "id": "llama3.2", "label": "Llama 3.2" },
        { "id": "qwen2.5-coder", "label": "Qwen 2.5 Coder" },
        { "id": "deepseek-r1", "label": "DeepSeek R1" }
      ]
    },
    {
      "id": "openai",
      "label": "OpenAI-compatible",
      "default_base_url": "https://api.openai.com/v1",
      "supports_custom_base_url": true,
      "supports_custom_model": true,
      "model_placeholder": "gpt-4.1-mini",
      "api_key_mode": "required",
      "api_key_label": "API key (session)",
      "api_key_placeholder": "sk-...",
      "transport": {
        "type": "http-json",
        "method": "POST",
        "path": "/chat/completions",
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer ${api_key}"
        },
        "body": {
          "model": "${model}",
          "temperature": "${temperature}",
          "messages": [
            { "role": "system", "content": "${system_prompt}" },
            { "role": "user", "content": "${user_prompt}" }
          ]
        },
        "response_text_paths": ["choices.0.message.content"]
      },
      "models": [
        { "id": "gpt-4.1-mini", "label": "GPT-4.1 mini" },
        { "id": "gpt-4.1", "label": "GPT-4.1" },
        { "id": "gpt-5-mini", "label": "GPT-5 mini" }
      ]
    },
    {
      "id": "anthropic",
      "label": "Anthropic",
      "default_base_url": "https://api.anthropic.com/v1",
      "supports_custom_base_url": true,
      "supports_custom_model": true,
      "model_placeholder": "claude-3-7-sonnet-latest",
      "api_key_mode": "required",
      "api_key_label": "API key (session)",
      "api_key_placeholder": "sk-ant-...",
      "transport": {
        "type": "http-json",
        "method": "POST",
        "path": "/messages",
        "headers": {
          "Content-Type": "application/json",
          "x-api-key": "${api_key}",
          "anthropic-version": "2023-06-01"
        },
        "body": {
          "model": "${model}",
          "temperature": "${temperature}",
          "max_tokens": 1024,
          "system": "${system_prompt}",
          "messages": [
            { "role": "user", "content": "${user_prompt}" }
          ]
        },
        "response_text_paths": ["content.*.text"]
      },
      "models": [
        { "id": "claude-3-5-haiku-latest", "label": "Claude 3.5 Haiku" },
        { "id": "claude-3-5-sonnet-latest", "label": "Claude 3.5 Sonnet" },
        { "id": "claude-3-7-sonnet-latest", "label": "Claude 3.7 Sonnet" }
      ]
    }
  ]
}
